   "source": [
    "Complete the solution so that it returns true if the first argument(string) passed in ends with the 2nd argument (also a string).\n",
    "\n",
    "Examples:\n",
    "\n",
    "Inputs: \"abc\", \"bc\"\n",
    "Output: true\n",
    "\n",
    "Inputs: \"abc\", \"d\"\n",
    "Output: false"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "d23c291a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "text = 'samurai'\n",
    "ending = \"ai\"\n",
    "\n",
    "print(text.endswith(ending))"
   ]
  }
